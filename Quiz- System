-- 6. ANALYTICS & REPORTING QUERIES
-- These queries help administrators view performance data.

-- A. View detailed results with Student names
SELECT 
    u.username AS 'Student Name', 
    r.score AS 'Marks Obtained', 
    r.total_questions AS 'Total Questions', 
    r.date_taken AS 'Submission Date'
FROM results r
JOIN users u ON r.user_id = u.user_id
ORDER BY r.date_taken DESC;

-- B. Global Leaderboard (High Scores per Student)
SELECT 
    u.username AS 'Student', 
    MAX(r.score) AS 'High Score'
FROM results r
JOIN users u ON r.user_id = u.user_id
GROUP BY u.username
ORDER BY `High Score` DESC;
