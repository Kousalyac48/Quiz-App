-- 1. DATABASE INITIALIZATION
-- Create the database if it doesn't exist and set it as the active context.
CREATE DATABASE IF NOT EXISTS quiz_system;
USE quiz_system;

-- 2. USER AUTHENTICATION TABLE
-- Stores login credentials and user roles (Admin vs Student).
CREATE TABLE IF NOT EXISTS users (
    user_id INT PRIMARY KEY AUTO_INCREMENT,
    username VARCHAR(50) UNIQUE NOT NULL,
    password VARCHAR(255) NOT NULL, -- Note: Store as plain text for demo; use hashing for production.
    role ENUM('Admin', 'Student') DEFAULT 'Student'
);

-- 3. QUESTION BANK TABLE
-- Stores the quiz questions, four options, and the identifier for the correct answer.
CREATE TABLE IF NOT EXISTS questions (
    q_id INT PRIMARY KEY AUTO_INCREMENT,
    question_text TEXT NOT NULL,
    option_a VARCHAR(255) NOT NULL,
    option_b VARCHAR(255) NOT NULL,
    option_c VARCHAR(255) NOT NULL,
    option_d VARCHAR(255) NOT NULL,
    correct_answer CHAR(1) NOT NULL -- Expected values: 'A', 'B', 'C', or 'D'
);

-- 4. QUIZ RESULTS TABLE
-- Tracks student performance, linking scores to users via a Foreign Key.
CREATE TABLE IF NOT EXISTS results (
    result_id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT,
    score INT NOT NULL,
    total_questions INT NOT NULL,
    date_taken TIMESTAMP DEFAULT CURRENT_TIMESTAMP, -- Automatically records time of completion
    FOREIGN KEY (user_id) REFERENCES users(user_id) ON DELETE CASCADE
);

